<resources>
    <!-- Android doesn't bundle actual Times New Roman (it's a Monotype
         font, not part of AOSP): "serif" is the closest built-in stand-in
         and gives the whole app that classic serif look everywhere text
         inherits the theme's default font, including views built in code. -->
    <style name="Theme.ReelsBlocker" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowBackground">#121212</item>
        <item name="colorPrimary">#26A69A</item>
        <item name="colorAccent">#26A69A</item>
        <item name="materialButtonStyle">@style/Widget.App.Button</item>
        <item name="android:fontFamily">serif</item>
        <item name="fontFamily">serif</item>
    </style>

    <!-- Flatter, rounder, lower-case buttons: swaps the default
         Material all-caps/elevated look for something more minimal. -->
    <style name="Widget.App.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">14dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:elevation">0dp</item>
        <item name="rippleColor">#33FFFFFF</item>
        <item name="android:fontFamily">serif</item>
        <item name="fontFamily">serif</item>
    </style>

    <!-- Custom dialogs (PIN entry) draw their own bg_card-backed root, so
         the system dialog chrome (white window background/corners) needs
         to get out of the way entirely instead of showing through/behind
         it: that's what read as "looks like old Android". -->
    <style name="Theme.App.Dialog" parent="Theme.MaterialComponents.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="colorAccent">#26A69A</item>
        <item name="android:fontFamily">serif</item>
        <item name="fontFamily">serif</item>
    </style>
</resources>
