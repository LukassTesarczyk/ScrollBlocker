<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#121212">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/btnOpenMenu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="›"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_icon_button"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvSelectedApp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Instagram"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#707070" />

        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="24dp">

                <!-- Home (Run/Stop status card lives only on this tab) -->
                <LinearLayout
                    android:id="@+id/overviewContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card"
                        android:padding="18dp"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:id="@+id/tvServiceStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textColor="#909090"
                            android:layout_marginBottom="16dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="10dp">

                            <Button
                                android:id="@+id/btnRun"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginEnd="6dp"
                                android:text="@string/run"
                                android:textColor="#FFFFFF"
                                android:backgroundTint="#26A69A" />

                            <Button
                                android:id="@+id/btnStop"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="6dp"
                                android:text="@string/stop"
                                android:textColor="#FFFFFF"
                                android:backgroundTint="#2E2E2E" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvPauseStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textColor="#909090"
                            android:gravity="center" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvNotImplementedNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#E0A030"
                        android:textSize="13sp"
                        android:visibility="gone"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_card"
                        android:padding="18dp"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tvTotalBlocked"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                android:textSize="30sp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />
                            <TextView
                                android:text="@string/total_blocked"
                                android:textColor="#808080"
                                android:textSize="12sp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tvTodayBlocked"
                                android:textColor="#26A69A"
                                android:textStyle="bold"
                                android:textSize="30sp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />
                            <TextView
                                android:text="@string/today"
                                android:textColor="#808080"
                                android:textSize="12sp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />
                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card"
                        android:padding="18dp">

                        <TextView
                            android:text="@string/last_7_days"
                            android:textColor="#808080"
                            android:textSize="13sp"
                            android:layout_marginBottom="10dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                        <LinearLayout
                            android:id="@+id/barsContainer"
                            android:layout_width="match_parent"
                            android:layout_height="150dp"
                            android:orientation="horizontal"
                            android:gravity="bottom" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card"
                        android:padding="18dp"
                        android:layout_marginTop="16dp">

                        <TextView
                            android:text="@string/time_spent_title"
                            android:textColor="#808080"
                            android:textSize="13sp"
                            android:layout_marginBottom="14dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <com.example.reelsblocker.DonutChartView
                                android:id="@+id/timeDonutChart"
                                android:layout_width="120dp"
                                android:layout_height="120dp"
                                android:layout_marginEnd="20dp" />

                            <LinearLayout
                                android:id="@+id/timeLegendContainer"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <!-- Setup: sectioned cards (Guide / Permissions / PIN) -->
                <LinearLayout
                    android:id="@+id/setupContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card"
                        android:padding="18dp"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:text="@string/section_guide"
                            android:textColor="#808080"
                            android:textSize="12sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="12dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                        <TextView
                            android:id="@+id/tvInstructions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="#CCCCCC"
                            android:lineSpacingExtra="3dp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card"
                        android:padding="18dp"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:text="@string/section_permissions"
                            android:textColor="#808080"
                            android:textSize="12sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="12dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                        <Button
                            android:id="@+id/btnOpenAccessibility"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/setup_open_accessibility"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#2E2E2E"
                            android:layout_marginBottom="10dp" />

                        <Button
                            android:id="@+id/btnOpenBatterySettings"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/setup_open_battery"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#2E2E2E"
                            android:layout_marginBottom="10dp" />

                        <Button
                            android:id="@+id/btnOpenOtherPermissions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/setup_open_other_permissions"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#2E2E2E" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card"
                        android:padding="18dp">

                        <TextView
                            android:text="@string/section_pin"
                            android:textColor="#808080"
                            android:textSize="12sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="12dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                        <TextView
                            android:text="@string/pin_description"
                            android:textColor="#909090"
                            android:textSize="13sp"
                            android:lineSpacingExtra="2dp"
                            android:layout_marginBottom="14dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />

                        <Button
                            android:id="@+id/btnPinToggle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/pin_enable"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#2E2E2E" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Debug -->
                <LinearLayout
                    android:id="@+id/debugContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="18dp"
                    android:visibility="gone">

                    <TextView
                        android:text="@string/debug_intro"
                        android:textColor="#808080"
                        android:textSize="12sp"
                        android:layout_marginBottom="14dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="14dp">

                        <Button
                            android:id="@+id/btnRefreshLog"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:text="@string/refresh"
                            android:textSize="12sp"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#2E2E2E" />

                        <Button
                            android:id="@+id/btnCopyLog"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:layout_marginEnd="4dp"
                            android:text="@string/copy"
                            android:textSize="12sp"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#2E2E2E" />

                        <Button
                            android:id="@+id/btnClearLog"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:text="@string/clear"
                            android:textSize="12sp"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#C62828" />

                    </LinearLayout>

                    <Button
                        android:id="@+id/btnDownloadLog"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/download_txt"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#2E2E2E"
                        android:layout_marginBottom="10dp" />

                    <Button
                        android:id="@+id/btnToggleDebugOverlay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/debug_overlay_off"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#2E2E2E"
                        android:layout_marginBottom="14dp" />

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="320dp"
                        android:background="#121212"
                        android:padding="10dp">

                        <TextView
                            android:id="@+id/tvLog"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#B0B0B0"
                            android:textSize="10sp"
                            android:fontFamily="monospace"
                            android:text="" />

                    </ScrollView>

                </LinearLayout>

                <!-- Languages -->
                <LinearLayout
                    android:id="@+id/languagesContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="10dp"
                    android:visibility="gone">

                    <TextView
                        android:text="@string/languages_title"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:padding="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <LinearLayout
                        android:id="@+id/languageList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#232323" />

        <!-- App hub: 3 fixed slots. Which app icon renders in which slot is
             dynamic (see MainActivity's hubOrder), so slots can be reordered
             by long-pressing one, then tapping where to move it. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="76dp"
            android:orientation="horizontal"
            android:background="#161616">

            <FrameLayout
                android:id="@+id/hubInstagram"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView
                        android:id="@+id/hubInstagramIcon"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:padding="6dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_instagram" />
                    <TextView
                        android:id="@+id/hubInstagramLabel"
                        android:text="Instagram"
                        android:textColor="#B0B0B0"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <TextView
                    android:id="@+id/hubInstagramBadge"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="6dp"
                    android:gravity="center"
                    android:text="⇄"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:visibility="gone" />

            </FrameLayout>

            <FrameLayout
                android:id="@+id/hubTiktok"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView
                        android:id="@+id/hubTiktokIcon"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:padding="6dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_tiktok" />
                    <TextView
                        android:id="@+id/hubTiktokLabel"
                        android:text="TikTok"
                        android:textColor="#B0B0B0"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <TextView
                    android:id="@+id/hubTiktokBadge"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="6dp"
                    android:gravity="center"
                    android:text="⇄"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:visibility="gone" />

            </FrameLayout>

            <FrameLayout
                android:id="@+id/hubSnapchat"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView
                        android:id="@+id/hubSnapchatIcon"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:padding="6dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_snapchat" />
                    <TextView
                        android:id="@+id/hubSnapchatLabel"
                        android:text="Snapchat"
                        android:textColor="#B0B0B0"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <TextView
                    android:id="@+id/hubSnapchatBadge"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="6dp"
                    android:gravity="center"
                    android:text="⇄"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:visibility="gone" />

            </FrameLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Slide-out menu: scrim + panel, both start hidden -->
    <View
        android:id="@+id/drawerScrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true" />

    <LinearLayout
        android:id="@+id/drawerPanel"
        android:layout_width="252dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="@drawable/bg_drawer_panel"
        android:elevation="12dp"
        android:paddingTop="28dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:visibility="gone">

        <TextView
            android:text="Reels Blocker"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="17sp"
            android:layout_marginStart="10dp"
            android:layout_marginBottom="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:id="@+id/btnMenuOverview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp"
            android:background="@drawable/bg_menu_item"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="4dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="14dp"
                android:tint="#FFFFFF"
                android:src="@drawable/ic_menu_home" />
            <TextView
                android:text="@string/menu_overview"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnMenuSetup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp"
            android:background="@drawable/bg_menu_item"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="4dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="14dp"
                android:tint="#FFFFFF"
                android:src="@drawable/ic_menu_settings" />
            <TextView
                android:text="@string/menu_settings"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnMenuDebug"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp"
            android:background="@drawable/bg_menu_item"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="4dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="14dp"
                android:tint="#FFFFFF"
                android:src="@drawable/ic_menu_log" />
            <TextView
                android:text="@string/menu_log"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnMenuLanguages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp"
            android:background="@drawable/bg_menu_item"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="14dp"
                android:tint="#FFFFFF"
                android:src="@drawable/ic_menu_languages" />
            <TextView
                android:text="@string/menu_languages"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:id="@+id/btnMenuShutdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp"
            android:background="@drawable/bg_menu_item"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="20dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="14dp"
                android:tint="#C62828"
                android:src="@drawable/ic_menu_power" />
            <TextView
                android:text="@string/shutdown_app"
                android:textColor="#C62828"
                android:textSize="15sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

    </LinearLayout>

    <!-- Hub long-press action sheet: scrim + small card above the hub bar -->
    <View
        android:id="@+id/hubSheetScrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true" />

    <LinearLayout
        android:id="@+id/hubActionSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="92dp"
        android:orientation="vertical"
        android:background="@drawable/bg_card"
        android:elevation="12dp"
        android:padding="10dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvHubSheetTitle"
            android:text="Instagram"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="15sp"
            android:padding="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/btnHubStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/hub_stats"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:padding="14dp"
            android:background="@drawable/bg_menu_item"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnHubMove"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/hub_move"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:padding="14dp"
            android:background="@drawable/bg_menu_item"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnHubToggleRun"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/stop"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:padding="14dp"
            android:background="@drawable/bg_menu_item"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</FrameLayout>
