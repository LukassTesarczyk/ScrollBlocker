<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="340dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:padding="22dp">

    <TextView
        android:id="@+id/tvPinDialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="17sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/etPinInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="numberPassword"
        android:maxLength="6"
        android:gravity="center"
        android:textSize="24sp"
        android:letterSpacing="0.5"
        android:textColor="#FFFFFF"
        android:textColorHint="#606060"
        android:textCursorDrawable="@null"
        android:background="@drawable/bg_pin_input"
        android:padding="14dp"
        android:layout_marginBottom="20dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnPinCancel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:text="@string/pin_cancel"
            android:backgroundTint="#2E2E2E"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnPinConfirm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:text="@string/pin_confirm"
            android:backgroundTint="#26A69A"
            android:textColor="#FFFFFF" />

    </LinearLayout>

</LinearLayout>
